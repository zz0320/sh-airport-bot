TELEGRAM_BOT_TOKEN=123456:replace_me

# Use "aviationstack" for live data, or "demo" to test bot behavior without a flight API key.
FLIGHT_PROVIDER=aviationstack
AVIATIONSTACK_API_KEY=replace_me

# Optional tuning.
POLL_TIMEOUT_SECONDS=30
FLIGHT_CACHE_SECONDS=45
DEFAULT_LIMIT=8

# Daily summary push, in Asia/Shanghai time.
DAILY_PUSH_TIME=08:30
DAILY_SUMMARY_LIMIT=4
DAILY_INCLUDE_PHOTOS=true
LIVE_REFRESH_SECONDS=300
SUBSCRIPTION_STORE=subscriptions.json

# Optional aircraft enrichment by ICAO24 / Mode-S. This improves registration, aircraft type, and photo hit rate.
AIRCRAFT_ENRICH_PROVIDER=adsbdb
AIRCRAFT_ENRICH_CACHE_SECONDS=86400

# Optional aircraft/livery photo lookup.
PHOTO_PROVIDER=auto
PHOTO_CACHE_SECONDS=86400
PHOTO_LIMIT=3
